{
  "exclude_repos": [],
  "public_repos_only": true,
  "environments": [
    {
      "name": "PyPi",
      "deployment_branch_policy": {
        "protected_branches": false,
        "custom_branch_policies": true
      },
      "deployment_branch_policies": [
        {
          "type": "tag",
          "name": "v*"
        }
      ]
    },
    {
      "name": "CloudFlare-R2",
      "deployment_branch_policy": {
        "protected_branches": false,
        "custom_branch_policies": true
      },
      "deployment_branch_policies": [
        {
          "type": "branch",
          "name": "*"
        },
        {
          "type": "branch",
          "name": "*/*"
        },
        {
          "type": "branch",
          "name": "*/*/*"
        },
        {
          "type": "tag",
          "name": "*"
        }
      ]
    }
  ]
}
